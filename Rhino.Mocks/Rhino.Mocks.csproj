      <DocumentationFile>Rhino.Mocks.XML</DocumentationFile>
      <CodeAnalysisRuleSet>AllRules.ruleset</CodeAnalysisRuleSet>
    </PropertyGroup>
    <ItemGroup>
  -->

</Project>
